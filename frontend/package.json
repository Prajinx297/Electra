    "@tanstack/react-query": "^5.28.4",
    "firebase": "^10.9.0",
    "framer-motion": "^11.0.14",
    "i18next": "^23.10.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^14.1.0",
    "react-router-dom": "^7.14.2",
    "reactflow": "^11.10.4",
    "recharts": "^2.12.3",
    "zod": "^4.4.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.8.5",
    "@playwright/test": "^1.42.1",
    "@testing-library/jest-dom": "^6.4.2",
