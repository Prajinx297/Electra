{
  "name": "electra",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:frontend dev:backend",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:backend": "python -m uvicorn backend.app.main:app --reload --host 0.0.0.0 --port 8000",
    "build": "npm --prefix frontend run build",
    "type-check": "npm --prefix frontend run type-check",
    "lint": "npm --prefix frontend run lint",
    "lint:fix": "npm --prefix frontend run lint:fix",
    "format": "npm --prefix frontend run format",
    "test": "npm --prefix frontend run test && python -m pytest backend/tests",
    "test:watch": "npm --prefix frontend run test:watch",
    "test:ui": "npm --prefix frontend run test:ui",
    "test:frontend": "npm --prefix frontend run test",
    "test:backend": "python -m pytest backend",
    "coverage": "npm --prefix frontend run test:coverage"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
